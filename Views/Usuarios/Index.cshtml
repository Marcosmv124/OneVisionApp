@model One_Vision.DTOs.LoginRequest

@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "One Vision";
}

<style>
    body {
        background-color: #f8f9fa;
    }

    .logo-container {
        text-align: center;
        margin-top: 40px;
    }

    .logo-container img {
        width: 180px;
        height: auto;
    }

    .card {
        border-radius: 12px;
        box-shadow: 0 6px 18px rgba(0, 0, 0, 0.1);
    }

    .btn-color {
        background-color: #253449;
        color: white;
        font-weight: 600;
        transition: background-color 0.3s ease;
    }

    .btn-color:hover {
        background-color: #C9B489;
        color: white;
    }

    .input-group-text {
        background-color: #f1f1f1;
        border-right: none;
    }

    .form-control {
        border-left: none;
    }

    .form-label {
        font-weight: 500;
    }

    .card-body {
        padding: 2.5rem;
    }

    .text-muted small {
        font-size: 0.85rem;
    }
</style>

<div class="logo-container">
    <img src="~/css/logo.png" alt="logo" />
</div>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0 mt-4">
                <div class="card-body">
                    <h4 class="text-center mb-4">
                        <i class="bi bi-person-circle me-2"></i>Iniciar Sesión
                    </h4>

                    <form asp-controller="Usuarios" asp-action="Index" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label asp-for="UsuarioNombre" class="form-label">Usuario</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-person"></i></span>
                                <input asp-for="UsuarioNombre" class="form-control" required />
                            </div>
                            <span asp-validation-for="UsuarioNombre" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Password" class="form-label">Contraseña</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-lock"></i></span>
                                <input asp-for="Password" type="password" class="form-control" id="passwordInput" required />
                            </div>
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <div class="form-check mb-3">
                            <input type="checkbox" class="form-check-input" id="mostrar" onclick="togglePasswordVisibility()" />
                            <label class="form-check-label" for="mostrar">Mostrar contraseña</label>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-color">
                                <i class="bi bi-box-arrow-in-right me-2"></i>Iniciar Sesión
                            </button>
                        </div>
                    </form>

                    <div class="text-center mt-3">
                        <p class="text-muted mb-0">
                            ¿No tienes una cuenta?
                            <a asp-action="Create" class="text-decoration-none fw-semibold" style="color: #253449;">Registrate ahora!</a>
                        </p>
                    </div>
                    <div class="text-center mt-3">
                        <p class="text-muted mb-0">
                            ¿Olvidaste la contraseña otra vez?
                            <a asp-action="Create" class="text-decoration-none fw-semibold" style="color: #253449;">Recupérala</a>
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function togglePasswordVisibility() {
        const input = document.getElementById("passwordInput");
        input.type = input.type === "password" ? "text" : "password";
    }
</script>
